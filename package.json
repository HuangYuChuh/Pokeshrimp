{
  "name": "pokeshrimp",
  "version": "0.1.0",
  "description": "Pokeshrimp — AI-powered image & video creative workstation",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && electron .",
    "dev:web": "next dev --port 3099",
    "build": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "next start",
    "lint": "next lint",
    "package": "npm run build && npm run build:electron && electron-builder --mac",
    "cli": "npx tsx src/cli/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.2.0",
    "@ai-sdk/react": "^1.2.0",
    "@base-ui/react": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ai": "^4.3.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.7.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "electron": "^35.1.0",
    "electron-builder": "^25.1.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  },
  "build": {
    "appId": "com.pokeshrimp.app",
    "productName": "Pokeshrimp",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics-design"
    },
    "extraResources": [
      {
        "from": ".next/static",
        "to": ".next/static"
      }
    ]
  },
  "author": "科林 KELIN <onepigge1999@gmail.com>",
  "license": "Apache-2.0"
}
