{
  "name": "pokeshrimp",
  "version": "0.1.0",
  "description": "Pokeshrimp — AI-powered image & video creative workstation",
  "private": true,
  "main": "dist-electron/main.js",
  "bin": {
    "pokeshrimp": "./bin/pokeshrimp.js"
  },
  "scripts": {
    "dev": "npm run build:electron && electron .",
    "dev:web": "next dev --port 3099",
    "build": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "package": "npm run build && npm run build:electron && electron-builder --mac",
    "build:cli": "tsc -p tsconfig.cli.json",
    "cli": "npx tsx src/cli/index.ts",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.2.0",
    "@ai-sdk/react": "^1.2.0",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@tailwindcss/typography": "^0.5.19",
    "ai": "^4.3.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "undici": "^8.0.2",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "^35.1.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.0",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.pokeshrimp.app",
    "productName": "Pokeshrimp",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics-design"
    },
    "extraResources": [
      {
        "from": ".next/static",
        "to": ".next/static"
      }
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0",
      "prettier --check"
    ]
  },
  "engines": {
    "node": ">=20.17.0",
    "npm": ">=10"
  },
  "author": "科林 KELIN <onepigge1999@gmail.com>",
  "license": "Apache-2.0"
}
